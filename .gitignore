# Root-level .gitignore for ShikkhaHub

# Dependencies
node_modules/
.pnp
.pnp.js

# Testing
coverage/
*.coverage
.nyc_output

# Production builds
dist/
dist-ssr/
build/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editor directories and files
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea
*.swp
*.swo
*~
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Package manager lock files (optional - uncomment if needed)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
bun.lockb

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Misc
.cache
*.local
.turbo
