# Backend .gitignore for Node.js/Express/MongoDB

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# Environment variables
.env
.env.local
.env.development
.env.test
.env.production
.env*.local

# Logs
logs/
*.log

# Database
*.sqlite
*.sqlite3
*.db

# Uploaded files (if you store uploads locally)
uploads/
public/uploads/

# Build outputs
dist/
build/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Testing
coverage/
.nyc_output/

# Temporary files
tmp/
temp/
*.tmp

# JWT keys (if storing locally)
*.pem
*.key
private.key
public.key
